    "item": [
        {
            "name": "Signup User",
            "event": [
                {
                    "listen": "prerequest",
                    "script": {
                        "exec": [
                            "pm.environment.set(\"random_user\", \"user\" + _.random(1000, 9999));\r",
                            "pm.environment.set(\"random_pwd\", \"pass\" + _.random(1000, 9999));"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"name\": \"Test User\",\n    \"username\": \"{{random_user}}\",\n    \"password\": \"{{random_pwd}}\"\n}"
                },
                "url": {
                    "raw": "{{BASE_URL}}/signup",
                    "host": [
                        "{{BASE_URL}}"
                    ],
                    "path": [
                        "signup"
                    ]
                }
            }
        },
