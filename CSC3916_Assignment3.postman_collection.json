        {
            "name": "Signin User",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var jsonData = pm.response.json();\r",
                            "if (jsonData.token) {\r",
                            "    pm.environment.set(\"jwt_token\", jsonData.token);\r",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"username\": \"{{random_user}}\",\n    \"password\": \"{{random_pwd}}\"\n}"
                },
                "url": {
                    "raw": "{{BASE_URL}}/signin",
                    "host": [
                        "{{BASE_URL}}"
                    ],
                    "path": [
                        "signin"
                    ]
                }
            }
        },
